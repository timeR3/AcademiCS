{
  "name": "academycs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint:frontend": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:frontend:strict": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:php": "node -e \"const fs=require('fs');const path=require('path');const cp=require('child_process');try{cp.execFileSync('php',['-v'],{stdio:'ignore'});}catch{console.error('PHP no está disponible en PATH');process.exit(1);}const files=[];const walk=d=>{for(const e of fs.readdirSync(d,{withFileTypes:true})){const p=path.join(d,e.name);if(e.isDirectory())walk(p);else if(e.isFile()&&p.endsWith('.php'))files.push(p);}};walk('backend-php');let failed=false;for(const f of files){try{cp.execFileSync('php',['-l',f],{stdio:'pipe'});}catch(err){failed=true;if(err.stdout)process.stdout.write(err.stdout.toString());if(err.stderr)process.stderr.write(err.stderr.toString());}}if(failed)process.exit(1);console.log('PHP lint OK: '+files.length+' archivos');\"",
    "lint": "npm run lint:frontend && npm run lint:php",
    "lint:strict": "npm run lint:frontend:strict && npm run lint:php",
    "test:frontend": "vitest run",
    "test:frontend:coverage": "vitest run --coverage",
    "test:backend": "cd backend-php && ./vendor/bin/phpunit",
    "test:e2e": "npx playwright test",
    "verify": "npm run lint:strict && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@genkit-ai/compat-oai": "^1.30.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "genkit": "^1.9.0",
    "lucide-react": "^0.542.0",
    "mysql2": "^3.15.0",
    "react": "^18.2.0",
    "react-confetti": "^6.4.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.62.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.18.1",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.46.1",
    "vite": "^5.4.20",
    "vitest": "^4.1.2"
  }
}
